# Database
# Local dev: SQLite (default)
DATABASE_URL=sqlite+aiosqlite:///./vibe_kanban.db
# Docker Compose: PostgreSQL (auto-set by docker-compose.yml)
# DATABASE_URL=postgresql+asyncpg://kanban:kanban@localhost:5436/kanban
# Railway: set in .env.railway (see below)
POSTGRES_PASSWORD=

# JWT
JWT_SECRET_KEY=change-me-to-a-random-secret
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# Google OAuth (optional)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8004/api/v1/auth/google/callback

# from railway (deploy)
RAILWAY_TOKEN=
# from your vibe-kanban app
VIBE_KANBAN_API_KEY=
VIBE_KANBAN_BASE_URL=http://localhost:8004/api/v1/external

# Contact form email (SMTP)
# Verify: ./scripts/verify_smtp.sh  (or --send-test to send test email)
# Email provider: smtp or resend
EMAIL_PROVIDER=smtp
CONTACT_ADMIN_EMAILS="your-email@gmail.com;"
SMTP_HOST=smtp.gmail.com
# Port: 587（TLS）or 465（SSL）
SMTP_PORT=587
SMTP_USER="your-email@gmail.com"
# https://myaccount.google.com/apppasswords
SMTP_APP_PASSWORD=
RESEND_FROM_EMAIL="your-email@your-domain.com"
RESEND_API_KEY=

# Rate limiter per IP (slowapi format: "count/period")
RATE_LIMIT_DEFAULT="60/minute"
RATE_LIMIT_REGISTER="1/3minutes"
RATE_LIMIT_LOGIN="10/minute"
RATE_LIMIT_FORGOT_PASSWORD="3/hour"
RATE_LIMIT_RESET_PASSWORD="5/hour"
RATE_LIMIT_CHANGE_PASSWORD="5/minute"
RATE_LIMIT_GOOGLE_AUTH="10/minute"
RATE_LIMIT_EXTERNAL="60/minute"
RATE_LIMIT_ADMIN="30/minute"

# Frontend URL (for CORS and OAuth redirect)
FRONTEND_URL=http://localhost:5177

# API
API_V1_PREFIX=/api/v1

# Environment files:
#   .env          — local development (SQLite, localhost)
#   .env.railway  — Railway production (PostgreSQL, real secrets)
#   Both are gitignored. Copy this file to get started:
#     cp .env.example .env
